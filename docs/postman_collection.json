          },
          "description": "Tests 404 response for a non-existent author ID."
        },
        {
          "name": "Book Not Found (404)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/books/99999", "host": ["{{base_url}}"], "path": ["api", "books", "99999"] }
          },
          "description": "Tests 404 response for a non-existent book ID."
        },
        {
          "name": "Member Not Found (404)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/members/99999", "host": ["{{base_url}}"], "path": ["api", "members", "99999"] }
          },
          "description": "Tests 404 response for a non-existent member ID."
        }
      ]
    }
  ]
}
